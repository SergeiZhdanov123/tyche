# Erns Terminal Backend Configuration
# Copy this to .env and fill in your values

# ============================================================
# POLYGON (Required for market data)
# ============================================================
POLYGON_API_KEY=arANpkgbG0ih2ohFx5MS6q2QbLGPvD1n

# ============================================================
# SEC API (Required)
# ============================================================
# Format: "Your Name your@email.com" (no brackets)
SEC_USER_AGENT=ErnsTerminal contact@tyche.io

# ============================================================
# DATABASE
# ============================================================
# SQLite (default, good for development)
EARNINGS_DB_URL=sqlite:///./earnings_intel.db

# PostgreSQL (for production)
# EARNINGS_DB_URL=postgresql://user:password@localhost:5432/tyche

# ============================================================
# RATE LIMITING (requests per minute by tier)
# ============================================================
RATE_STARTER_RPM=30
RATE_PREMIUM_RPM=120
RATE_ENTERPRISE_RPM=600

# ============================================================
# OPTIONAL INTEGRATIONS
# ============================================================

# News API (for /company/{ticker}/news)
# Get key at: https://newsapi.org/
NEWS_API_KEY=6d0475d881184d538983bb3edc9aac27

# DeepSeek API Key (Erns AI Chat)
DEEPSEEK_API_KEY=sk-7436f45a858e486f91ebab0f30bf47a9
# DeepSeek AI (for /company/{ticker}/earnings-ai-review)


# ============================================================
# SEC REQUEST THROTTLING
# ============================================================
# Delay between SEC API requests (seconds)
SEC_REQ_DELAY_SEC=0.25
CORS_ORIGINS=https://tychefinancials.com
API_BASE_URL	=https://api.tychefinancials.com
PYTHON_VERSION=	3.13.0